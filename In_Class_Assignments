        "# Loan Payment Calculator\n",
        "\n",
        "def loan_payment(principal, annual_rate, years):\n",
        "    assert isinstance(principal, (int, float))\n",
        "    assert isinstance(annual_rate, (int, float))\n",
        "    assert isinstance(years, (int, float))\n",
        "    assert principal > 0 and annual_rate > 0 and years > 0, \"All inputs must be positive\"\n",
        "\n",
        "    r = annual_rate / 12\n",
        "    n = years * 12\n",
        "\n",
        "    if r != 0:\n",
        "        monthly_payment = (r * principal) / (1 - (1 + r) ** (-n))\n",
        "    else:\n",
        "        monthly_payment = principal / n\n",
        "\n",
        "    return monthly_payment\n",
        "\n",
        "principal = float(input(\"Enter loan amount: \"))\n",
        "annual_rate = float(input(\"Enter annual interest rate (as decimal, e.g. 0.05): \"))\n",
        "years = float(input(\"Enter loan term in years: \"))\n",
        "\n",
        "print(f\"Monthly Payment: ${loan_payment(principal, annual_rate, years):.2f}\")"
