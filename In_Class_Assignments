        "    def calculate_pay(self): return self.__wage * self.hours\n",
        "    def display_info(self):\n",
        "        print(f\"{self.name} | Wage: ${self.__wage} | Hours: {self.hours} | Pay: ${self.calculate_pay()}\")\n",
