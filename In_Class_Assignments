        "# Classes Point and Rectangle\n",
        "\n",
        "class Point:\n",
        "    def __init__(self, x, y):\n",
        "        self.x = x\n",
        "        self.y = y\n",
        "\n",
        "    def distance(self, other):\n",
        "        dx = (self.x - other.x) ** 2\n",
        "        dy = (self.y - other.y) ** 2\n",
        "        return (dx + dy) ** 0.5\n",
        "\n",
        "\n",
        "class Rectangle:\n",
        "    def __init__(self, p1, p2, p3, p4):\n",
        "        self.p1 = p1\n",
        "        self.p2 = p2\n",
        "        self.p3 = p3\n",
        "        self.p4 = p4\n",
        "        self.width = p1.distance(p2)\n",
        "        self.height = p1.distance(p4)\n",
        "\n",
        "    def get_width(self):\n",
        "        return self.width\n",
        "\n",
        "    def get_height(self):\n",
        "        return self.height\n",
        "\n",
        "    def get_area(self):\n",
        "        return self.width * self.height\n",
        "\n",
        "p1, p2, p3, p4 = Point(0,0), Point(4,0), Point(4,3), Point(0,3)\n",
        "r = Rectangle(p1, p2, p3, p4)\n",
        "print(f\"Width: {r.get_width()}\")\n",
        "print(f\"Height: {r.get_height()}\")\n",
        "print(f\"Area: {r.get_area()}\")"
